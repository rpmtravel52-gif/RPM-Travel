# ─── Fonnte WhatsApp API ──────────────────────────────────────
# Dapatkan token di: https://fonnte.com/
FONNTE_TOKEN=ISI_TOKEN_FONNTE_KAMU_DISINI

# Nomor admin yang menerima notifikasi booking masuk
# Pisahkan dengan koma jika lebih dari satu nomor
# Format: 62xxx (tanpa + dan tanpa spasi)
ADMIN_WA_NUMBERS=6281373336728,6285282828005

# ─── Base URL (dipakai di link dashboard dalam pesan WA admin) ─
NEXT_PUBLIC_BASE_URL=https://rpmtravel.co.id

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── QRIS Static String ───────────────────────────────────────
NEXT_PUBLIC_QRIS_STATIC=ISI_QRIS_STATIC_KAMU

# ─── Resend (email) ───────────────────────────────────────────
RESEND_API_KEY=ISI_RESEND_API_KEY_KAMU
